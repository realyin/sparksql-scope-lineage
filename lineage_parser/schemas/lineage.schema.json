{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FieldLineage",
  "type": "object",
  "required": ["task_id", "target_table", "stmt_kind", "scopes", "scope_graph"],
  "additionalProperties": true,
  "properties": {
    "task_id":       { "type": "string", "minLength": 1 },
    "target_table":  { "type": "string", "minLength": 1 },
    "stmt_kind":     {
      "type": "string",
      "enum": ["INSERT_OVERWRITE", "INSERT", "CTAS", "MERGE", "UPDATE", "DELETE", "UNKNOWN"]
    },
    "source_tables": { "type": "array", "items": { "type": "string" } },
    "related_metadata": {
      "type": "object",
      "properties": {
        "input_tables": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/table_metadata" }
        },
        "output_tables": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/table_metadata" }
        }
      }
    },
    "partition_columns": { "type": "array", "items": { "type": "string" } },
    "end_to_end_lineage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["column", "transform", "trace_complete", "physical_sources"],
        "properties": {
          "column": { "type": "string" },
          "transform": { "type": "string" },
          "trace_complete": { "type": "boolean" },
          "trace_incomplete_reasons": {
            "type": "array",
            "items": { "type": "string" }
          },
          "physical_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["table", "column", "transform"],
              "properties": {
                "table": { "type": "string" },
                "column": { "type": "string" },
                "transform": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "scope_profile": {
      "type": "object",
      "properties": {
        "profile_step_count": { "type": "integer" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "scope_id",
              "name",
              "kind",
              "role",
              "operations",
              "direct_inputs",
              "physical_source_tables",
              "output_columns",
              "logic"
            ],
            "properties": {
              "scope_id": { "type": "string" },
              "name": { "type": "string" },
              "kind": { "type": "string" },
              "role": { "type": "string" },
              "operations": { "type": "array", "items": { "type": "string" } },
              "direct_inputs": { "type": "array", "items": { "type": "string" } },
              "physical_source_tables": { "type": "array", "items": { "type": "string" } },
              "output_columns": { "type": "integer" },
              "logic": {
                "type": "object",
                "properties": {
                  "joins": { "type": "array" },
                  "filters": { "type": "array", "items": { "type": "string" } },
                  "aggregations": { "type": "array" },
                  "window_functions": { "type": "array" },
                  "case_when": { "type": "array" },
                  "key_renames": { "type": "array" },
                  "distinct": { "type": "boolean" },
                  "union_branches": { "type": "integer" },
                  "lateral_views": { "type": "array" }
                }
              }
            }
          }
        }
      }
    },
    "scope_graph": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "array" },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to":   { "type": "string" }
            }
          }
        }
      }
    },
    "scopes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "columns", "depends_on"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["physical_table", "cte", "subquery", "union", "union_branch", "root"]
          },
          "distinct": { "type": "boolean" },
          "lateral_views": { "type": "array" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "transform", "sources"],
              "properties": {
                "name":      { "type": "string", "minLength": 1 },
                "transform": {
                  "type": "string",
                  "enum": ["DIRECT", "EXPRESSION", "AGGREGATE", "WINDOW",
                           "CONDITIONAL", "CONSTANT", "UNION", "EXPAND_ALL"]
                },
                "sources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["scope", "column"],
                    "properties": {
                      "scope":  { "type": "string" },
                      "column": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "fallback_used": { "type": "boolean" },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "scope", "msg"],
            "properties": {
              "type":  { "type": "string" },
              "scope": { "type": "string" },
              "msg":   { "type": "string" }
            }
          }
        },
        "stats": { "type": "object" }
      }
    }
  },
  "definitions": {
    "table_metadata": {
      "type": "object",
      "required": ["column_details", "metadata_complete"],
      "properties": {
        "column_details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": ["string", "null"] },
              "comment": { "type": ["string", "null"] }
            }
          }
        },
        "metadata_complete": { "type": "boolean" }
      }
    }
  }
}
